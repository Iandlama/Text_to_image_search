# Copy to .env - it is auto-loaded on import.
# All keys are optional; they override models.yaml / defaults at runtime.

MEME_EMBEDDER_MODEL=clip-jina-v2          # which registry entry to load by default
MEME_EMBEDDER_CONFIG=./models.yaml        # path to the model registry YAML
MEME_EMBEDDER_DEVICE=cuda                 # cuda | cpu   (auto-detected if unset)
MEME_EMBEDDER_DTYPE=auto                  # auto | float32 | float16 | bfloat16
MEME_EMBEDDER_LOG_LEVEL=INFO              # DEBUG | INFO | WARNING | ERROR
# MEME_EMBEDDER_CACHE_DIR=/data/hf-cache  # HF weights cache directory

# Needed only for gated models (e.g. Gemma) - standard HF variable:
# HF_TOKEN=hf_xxx
